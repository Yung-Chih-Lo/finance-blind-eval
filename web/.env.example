# Gateway base URL. Do NOT include /chat/completions — the server appends both
# /chat/completions and /models itself. A base ending with /chat/completions or
# /completions, or carrying a query string / fragment, is rejected on save.
OPENAI_COMPAT_API_BASE_URL=http://127.0.0.1:8080/v1
OPENAI_COMPAT_TEMPERATURE=0.2
OPENAI_COMPAT_MAX_TOKENS=1200

# Optional. Overrides the derived ${OPENAI_COMPAT_API_BASE_URL}/models when
# models discovery lives on a different host. Leave empty in most cases.
OPENAI_COMPAT_MODELS_ENDPOINT=

# Optional. Only needed if /v1/models exposes more than three models or names cannot be inferred.
OPENAI_COMPAT_MODEL_H1=
OPENAI_COMPAT_MODEL_H2=
OPENAI_COMPAT_MODEL_TAIDE=

# Server-side only. Do not create NEXT_PUBLIC_* API key variables.
# Admin UI stores this env var name, not the raw secret.
OPENAI_COMPAT_API_KEY_ENV=OPENAI_COMPAT_API_KEY
OPENAI_COMPAT_API_KEY=

# Optional prompt defaults. The admin UI can override these at runtime.
OPENAI_COMPAT_SYSTEM_PROMPT=
OPENAI_COMPAT_USER_PROMPT_TEMPLATE=

# Preferred admin entry for shared deployments:
#   /admin?token=<ADMIN_LINK_TOKEN>
# Prefer ADMIN_LINK_TOKEN_SHA256 in hosted environments so the raw link token is not stored in deployment config.
ADMIN_LINK_TOKEN=
ADMIN_LINK_TOKEN_SHA256=
ADMIN_SESSION_SECRET=

# Basic Auth fallback for /admin and /api/admin/*. Local dev allows admin without auth if no admin auth is configured.
ADMIN_PASSWORD=

# Optional. Stored under .data/. Defaults to evaluation-store.json.
EVALUATION_DATA_FILE=

# Optional. Stored under .data/. Defaults to platform-settings.json.
PLATFORM_SETTINGS_FILE=
