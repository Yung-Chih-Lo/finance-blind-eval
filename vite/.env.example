VITE_OPENAI_COMPAT_API_ENDPOINT=http://127.0.0.1:8080/v1/chat/completions
VITE_OPENAI_COMPAT_TEMPERATURE=0.2

# Optional. By default the app derives this as /v1/models from the chat endpoint.
VITE_OPENAI_COMPAT_MODELS_ENDPOINT=http://127.0.0.1:8080/v1/models

# Optional. Only needed if /v1/models returns more than 3 models or names cannot be inferred.
VITE_OPENAI_COMPAT_MODEL_H1=
VITE_OPENAI_COMPAT_MODEL_H2=
VITE_OPENAI_COMPAT_MODEL_TAIDE=

# Local demo only. For a public study, keep the key behind a backend proxy.
VITE_OPENAI_COMPAT_API_KEY=
